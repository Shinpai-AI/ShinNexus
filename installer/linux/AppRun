#!/bin/bash
HERE="$(dirname "$(readlink -f "$0")")"
NEXUS_SRC="$HERE/usr/share/shinnexus"
DEFAULT_DIR="$HOME/.local/share/shinnexus"
LOGFILE="/tmp/shinnexus-appimage.log"
ICON="$HERE/shinnexus.png"

# === INSTALLER-DIALOG ===
if [ -n "$APPIMAGE" ] && [ ! -f "$DEFAULT_DIR/ShinNexus.py" ]; then
  CHOICE=$(zenity --question \
    --title="ShinNexus" \
    --window-icon="$ICON" \
    --text="Willkommen bei ShinNexus!\n\n<b>Was passiert:</b>\n• Server wird installiert\n• Desktop-Icon wird erstellt\n• Python-Umgebung wird eingerichtet\n• Browser oeffnet sich automatisch\n\n<b>Erster Start dauert ~1-2 Minuten</b>\n\nJetzt installieren und starten?" \
    --ok-label="Installieren" \
    --cancel-label="Abbrechen" \
    --width=450 2>/dev/null; echo $?)

  [ "$CHOICE" != "0" ] && exit 0

  CUSTOM_DIR=$(zenity --file-selection --directory \
    --title="Installationsordner waehlen" \
    --window-icon="$ICON" \
    --filename="$DEFAULT_DIR/" \
    --width=500 --height=400 2>/dev/null)

  if [ -n "$CUSTOM_DIR" ]; then
    DEFAULT_DIR="$CUSTOM_DIR"
  fi
fi

WORK_DIR="$DEFAULT_DIR"

# 1. Dateien kopieren/updaten
if [ ! -f "$WORK_DIR/ShinNexus.py" ]; then
  mkdir -p "$WORK_DIR"
  cp -r "$NEXUS_SRC"/* "$WORK_DIR/"
  chmod +x "$WORK_DIR/start.sh" 2>/dev/null
fi
[ "$NEXUS_SRC/ShinNexus.py" -nt "$WORK_DIR/ShinNexus.py" ] 2>/dev/null && cp "$NEXUS_SRC/ShinNexus.py" "$NEXUS_SRC/requirements.txt" "$WORK_DIR/" 2>/dev/null

# 2. Desktop-Icon (absoluter Pfad zum Logo!)
if [ -n "$APPIMAGE" ] && [ ! -f "$HOME/.local/share/applications/shinnexus.desktop" ]; then
  mkdir -p "$HOME/.local/share/applications"
  # Icon in Installationsordner kopieren
  cp "$HERE/shinnexus.png" "$WORK_DIR/shinnexus.png" 2>/dev/null
  cat > "$HOME/.local/share/applications/shinnexus.desktop" << EOF
[Desktop Entry]
Name=ShinNexus
Comment=Decentralized Identity Service
Exec=/usr/bin/python3 $WORK_DIR/shinnexus-tray.py
Icon=$WORK_DIR/shinnexus.png
Terminal=false
Type=Application
Categories=Network;Security;
EOF
  chmod +x "$HOME/.local/share/applications/shinnexus.desktop"
  # Auch ins hicolor Theme
  mkdir -p "$HOME/.local/share/icons/hicolor/512x512/apps"
  cp "$HERE/shinnexus.png" "$HOME/.local/share/icons/hicolor/512x512/apps/shinnexus.png" 2>/dev/null
  update-desktop-database "$HOME/.local/share/applications" 2>/dev/null
fi

cd "$WORK_DIR"

# 3. venv + deps
if [ ! -f "$WORK_DIR/env/bin/python3" ]; then
  (
    echo "10"; echo "# Python-Umgebung erstellen..."
    python3 -m venv "$WORK_DIR/env" >> "$LOGFILE" 2>&1
    echo "30"; echo "# Pakete installieren..."
    "$WORK_DIR/env/bin/pip" install --upgrade pip -q >> "$LOGFILE" 2>&1
    echo "60"; echo "# Abhaengigkeiten installieren..."
    "$WORK_DIR/env/bin/pip" install -r "$WORK_DIR/requirements.txt" -q >> "$LOGFILE" 2>&1
    echo "100"; echo "# Fertig!"
  ) | zenity --progress --title="ShinNexus" \
      --window-icon="$ICON" \
      --text="Erster Start - Umgebung wird eingerichtet..." \
      --percentage=0 --auto-close --no-cancel --width=400 2>/dev/null
fi

# 4. Tray-Icon starten
exec /usr/bin/python3 "$WORK_DIR/shinnexus-tray.py"
